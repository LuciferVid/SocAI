# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=logs.raw
KAFKA_TOPIC_SCORED=logs.scored
KAFKA_TOPIC_ALERTS=alerts
KAFKA_CONSUMER_GROUP=soc-pipeline

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://soc_user:soc_pass_dev@localhost:5432/soc_db

# Redis
REDIS_URL=redis://localhost:6379/0

# ML
ANOMALY_THRESHOLD=0.7
MODEL_DIR=app/ml/artifacts

# Alerts
ALERT_COOLDOWN_SECONDS=60
WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# App
LOG_LEVEL=INFO
